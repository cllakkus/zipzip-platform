{
  "name": "zipzip",
  "version": "1.0.0",
  "private": true,
  "description": "ZIPZIP — 2D platform oyunu (web + mobil)",
  "scripts": {
    "copy": "node -e \"const fs=require('fs');fs.mkdirSync('www',{recursive:true});fs.copyFileSync('index.html','www/index.html')\"",
    "sync": "npm run copy && npx cap sync",
    "add:android": "npm run copy && npx cap add android",
    "open:android": "npx cap open android",
    "add:ios": "npm run copy && npx cap add ios",
    "open:ios": "npx cap open ios",
    "gen:assets": "node tools/gen-assets.js",
    "assets": "npx @capacitor/assets generate"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/android": "^6.1.0",
    "@capacitor/ios": "^6.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0"
  }
}
